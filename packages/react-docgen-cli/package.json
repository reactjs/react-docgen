{
  "name": "@react-docgen/cli",
  "version": "4.0.0",
  "description": "A CLI to extract information from React components for documentation generation.",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "type": "git",
