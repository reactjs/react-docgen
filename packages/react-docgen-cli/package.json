  },
  "license": "MIT",
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "debug": "4.4.3",
    "fast-glob": "3.3.3",
    "react-docgen": "workspace:9.0.0",
    "slash": "5.1.0"
  },
  "devDependencies": {
    "@types/debug": "4.1.13"
  }
}
